# MToolKit Environment Configuration
# Copy this file to .env in your project root (same directory as Assets/)
# For build automation, create separate files: .env.dev, .env.stage, .env.prod
# Never commit .env files with real values to source control!

# Environment identifier (dev/stage/prod)
# Used for log enrichment and environment-specific configuration
# Defaults to "default" if not set
ENVIRONMENT=dev

# Alternative environment variable name (checked if ENVIRONMENT is not set)
# MT_ENVIRONMENT=dev

# Example values:
# ENVIRONMENT=dev      # Development environment
# ENVIRONMENT=stage     # Staging environment  
# ENVIRONMENT=prod      # Production environment

